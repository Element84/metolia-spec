{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 214: an extension non-success type through dispatch, catch, and re-raise.",
  "entrypoint": "fail",
  "steps": {
    "fail": {
      "action": "Call",
      "call": {
        "provider": "mwl:provider.call/mwl/mock/v1",
        "with": {
          "failure": {
            "type": "ProcessingError",
            "code": "Conformance.DomainFailure",
            "message": "domain failure"
          }
        }
      },
      "next": "done",
      "catch": [
        {
          "match": {
            "codes": [
              "Conformance.DomainFailure"
            ]
          },
          "next": "reraise"
        }
      ]
    },
    "reraise": {
      "action": "Raise"
    },
    "done": {
      "action": "Return"
    }
  }
}
