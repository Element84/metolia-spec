{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 420: each dispatch retries inside its own frame; one exhausts.",
  "entrypoint": "fan-out",
  "steps": {
    "fan-out": {
      "action": "Gather",
      "over": "{{ step.input }}",
      "call": {
        "flow": {
          "entrypoint": "attempt",
          "steps": {
            "attempt": {
              "action": "Call",
              "middleware": [
                {
                  "provider": "mwl:provider.middleware/mwl/retry/v1",
                  "onEntry": {
                    "with": {
                      "policies": [
                        {
                          "match": {
                            "codes": [
                              "Conformance.*"
                            ]
                          },
                          "attempts": 2
                        }
                      ]
                    }
                  }
                }
              ],
              "call": {
                "provider": "mwl:provider.call/mwl/mock/v1",
                "with": {
                  "failure": "{{ call.input == 'b' ? {'code': 'Conformance.InjectedFailure', 'message': 'injected'} : null }}"
                }
              },
              "next": "done"
            },
            "done": {
              "action": "Return"
            }
          }
        }
      },
      "next": "done"
    },
    "done": {
      "action": "Return"
    }
  }
}
