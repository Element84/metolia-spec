{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 110: an uncaught dispatch failure becomes the Flow's Result.",
  "entrypoint": "fail",
  "steps": {
    "fail": {
      "action": "Call",
      "call": {
        "provider": "mwl:provider.call/mwl/mock/v1",
        "with": {
          "failure": {
            "code": "Conformance.InjectedFailure",
            "message": "injected",
            "details": { "hint": "conformance" },
            "retryable": true
          }
        }
      },
      "next": "done"
    },
    "done": { "action": "Return" }
  }
}
