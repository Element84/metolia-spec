{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 411: a one-success policy tolerates dispatch failures.",
  "entrypoint": "fan-out",
  "steps": {
    "fan-out": {
      "action": "Gather",
      "over": "{{ step.input }}",
      "call": {
        "provider": "mwl:provider.call/mwl/mock/v1",
        "with": {
          "failure": "{{ call.input == 'b' ? {'code': 'Conformance.InjectedFailure', 'message': 'injected'} : null }}"
        }
      },
      "completion": { "successes": 1 },
      "next": "done"
    },
    "done": { "action": "Return" }
  }
}
