{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 630: the cleanup call fails and supersedes the success in flight.",
  "entrypoint": "work",
  "steps": {
    "work": {
      "action": "Call",
      "middleware": [
        {
          "provider": "mwl:provider.middleware/mwl/finally/v1",
          "onAlways": {
            "with": {
              "call": {
                "provider": "mwl:provider.call/mwl/mock/v1",
                "with": {
                  "failure": {
                    "code": "Conformance.CleanupFailed",
                    "message": "cleanup failed"
                  }
                }
              }
            }
          }
        }
      ],
      "call": {
        "provider": "mwl:provider.call/mwl/mock/v1",
        "with": { "value": "ok" }
      },
      "next": "done"
    },
    "done": { "action": "Return" }
  }
}
