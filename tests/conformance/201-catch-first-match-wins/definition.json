{
  "$schema": "https://mwl.dev/v0.1/flow/schema.json",
  "comment": "Conformance 201: the first matching catch clause wins.",
  "entrypoint": "charge",
  "steps": {
    "charge": {
      "action": "Call",
      "call": {
        "provider": "mwl:provider.call/mwl/mock/v1",
        "with": {
          "failure": {
            "code": "Conformance.CardDeclined"
          }
        }
      },
      "next": "done",
      "catch": [
        {
          "match": {
            "codes": [
              "Conformance.*"
            ]
          },
          "output": "prefix-clause",
          "next": "recover"
        },
        {
          "match": {
            "codes": [
              "*"
            ]
          },
          "output": "wildcard-clause",
          "next": "recover"
        }
      ]
    },
    "recover": {
      "action": "Return"
    },
    "done": {
      "action": "Return"
    }
  }
}
